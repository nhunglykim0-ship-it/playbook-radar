# ============================================
# Playbook Radar 环境变量配置
# Vercel + Supabase + GitHub Actions
# ============================================

# ============================================
# 本地开发 (.env.local)
# ============================================

# Supabase 数据库连接
# 在 Supabase Dashboard -> Settings -> Database 获取
DATABASE_URL="postgresql://postgres.[project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase API (可选，用于管理操作)
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_KEY="your-supabase-anon-key"

# AI API 配置
API_KEY="your-api-key"
API_BASE_URL="http://1.95.142.151:3000/v1"

# YouTube API (可选)
YOUTUBE_API_KEY="your-youtube-api-key"

# 分析工具
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="your-domain.com"
NEXT_PUBLIC_PLAUSIBLE_URL="https://plausible.io/js/script.js"

# ============================================
# Vercel 环境变量
# ============================================
# 在 Vercel Dashboard -> Project Settings -> Environment Variables 添加

# Production
DATABASE_URL=postgresql://...
API_KEY=your-api-key
API_BASE_URL=http://1.95.142.151:3000/v1
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# Preview (可选，与 Production 相同)
DATABASE_URL=postgresql://...
API_KEY=your-api-key
API_BASE_URL=http://1.95.142.151:3000/v1

# ============================================
# GitHub Actions Secrets
# ============================================
# 在 GitHub Repository -> Settings -> Secrets and variables -> Actions 添加

# 必需
DATABASE_URL=postgresql://...
API_KEY=your-api-key
API_BASE_URL=http://1.95.142.151:3000/v1

# 可选
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=your-supabase-anon-key
