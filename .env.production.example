# ============================================
# Playbook Radar - 生产环境配置示例
# ============================================
# 部署到 Vercel 时，将这些变量配置到 Vercel Secrets
# 本地生产测试可复制为 .env.production

# 数据库：Supabase Postgres (生产)
# 从 Supabase Dashboard 获取连接字符串
DATABASE_URL="postgresql://postgres.xxx:password@aws-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"

# AI API 配置 (必需)
API_KEY="sk-your-api-key-here"
API_BASE_URL="https://coding.dashscope.aliyuncs.com/v1"

# YouTube API (可选)
# YOUTUBE_API_KEY=""

# 分析工具 (可选)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# NEXT_PUBLIC_PLAUSIBLE_URL=""
