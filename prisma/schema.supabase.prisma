// ============================================
// Playbook Radar - Supabase/Postgres 生产 Schema
// 使用方法：
//   1. 复制此文件覆盖 schema.prisma
//   2. 配置 DATABASE_URL 为 Supabase 连接字符串
//   3. 运行：npx prisma db push
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id              String    @id @default(cuid())
  sourceType      String    // youtube, x, blog, github
  sourceId        String    // 原始 ID (video_id, tweet_id)
  url             String    @unique
  titleRaw        String
  titleCn         String?
  descriptionRaw  String?
  descriptionCn   String?
  author          String?
  publishedAt     DateTime
  fetchedAt       DateTime  @default(now())
  status          String    @default("PENDING")
  heatScore       Float     @default(0)
  views           Int       @default(0)
  likes           Int       @default(0)
  comments        Int       @default(0)
  isDuplicateOf   String?
  duplicateOf     Item?     @relation("DuplicateItems", fields: [isDuplicateOf], references: [id])
  duplicates      Item[]    @relation("DuplicateItems")
  tags            ItemTag[]
  
  oneLiner        String?
  difficulty      String?
  cost            String?
  agentUsage      Int       @default(1)
  businessPotential Int     @default(5)
  timeToBuild     String?
  tools           String?   // JSON
  steps           String?   // JSON
  resources       String?   // JSON
  score           Float     @default(0)
  cluster         String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sourceType, sourceId])
  @@index([status])
  @@index([heatScore])
  @@index([publishedAt])
  @@index([cluster])
  @@index([score])
  @@index([difficulty])
  @@map("items")
}

model Tag {
  id          String      @id @default(cuid())
  name        String      @unique
  category    String
  description String?
  items       ItemTag[]
  createdAt   DateTime    @default(now())

  @@map("tags")
}

model ItemTag {
  itemId    String
  tagId     String
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@id([itemId, tagId])
  @@map("item_tags")
}

model DailyDigest {
  id          String   @id @default(cuid())
  date        String   @unique
  itemsJson   String
  summary     String
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("daily_digests")
}
